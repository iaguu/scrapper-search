# Telegram API Credentials
# Get these from my.telegram.org
API_ID=
API_HASH=

# The username or ID of the chat/channel/bot you want to interact with.
# For a bot, this is usually the bot's username (e.g., "MyBot").
# For a channel or group, you can get the ID from the URL or by using a bot to get the chat ID.
CHAT_ID=

# Your phone number, including the country code (e.g., "+15551234567").
PHONE_NUMBER=

# A secret key to protect your API endpoints.
# This can be any random string.
API_KEY=your-secret-api-key